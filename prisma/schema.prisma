generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

////////////////////////////////////////////////////////////
// ENUMS
////////////////////////////////////////////////////////////

enum UserRole {
  OWNER
  ADMIN
  CASHIER
}

enum OrderStatus {
  PENDING // La orden ha sido creada pero el pago no se ha confirmado (común en web)
  PAID // Pago confirmado, esperando a que alguien tome la orden
  PREPARING // "Lista para empaquetar" / En proceso de empaque (Ventas con envío)
  READY // Empaquetada y lista para ser retirada por el transporte o cliente
  SHIPPED // En camino
  DELIVERED // Entregada con éxito (Estado final de una venta física normal)
  CANCELLED // Cancelada por el cliente o admin
  REFUNDED // El dinero fue devuelto
}

enum DeliveryType {
  IN_STORE_PICKUP // Entrega en tienda física
  SHIPPING // Envío a domicilio / Otra ciudad
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  PAYMENT_LINK
  POINTS
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum SaleChannel {
  POS
  WEB
}

////////////////////////////////////////////////////////////
// ADMINISTRACIÓN
////////////////////////////////////////////////////////////

model User {
  //Informacion básica
  id       Int      @id @default(autoincrement())
  uuid     String   @unique @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(CASHIER)

  //Seguridad
  refreshToken String?
  quickPin     String? //nuevo

  mustChangePassword Boolean @default(true)
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processedOrders Order[]
}

model BillingConfig {
  id      Int         @id @default(autoincrement())
  uuid    String      @unique @default(uuid())
  channel SaleChannel

  cai             String
  rangeFrom       String
  rangeTo         String
  limitDate       DateTime
  prefix          String
  currentSequence Int
  isActive        Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

////////////////////////////////////////////////////////////
// CATÁLOGO
////////////////////////////////////////////////////////////

model Category {
  id          Int     @id @default(autoincrement())
  uuid        String  @unique @default(uuid())
  name        String
  description String?
  position    Int
  imageURL    String?
  parentId    Int?

  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]

  @@unique([name, parentId])
}

model Product {
  id          Int     @id @default(autoincrement())
  uuid        String  @unique @default(uuid())
  name        String
  description String?
  sku         String  @unique

  //Finanzas
  cost  Decimal @db.Decimal(10, 2)
  price Decimal @db.Decimal(10, 2)

  //Descuentos
  isOnDiscount  Boolean @default(false)
  discountPrice Decimal @default(0) @db.Decimal(10, 2)

  //Fidelización
  isReward    Boolean @default(false)
  pointsValue Int     @default(0)

  //Inventario
  minStock Int     @default(0)
  stock    Int     @default(0)
  isActive Boolean @default(true)

  //Relaciones
  categoryId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   Category       @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  uuid      String  @unique @default(uuid())
  url       String
  isPrimary Boolean @default(false)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

////////////////////////////////////////////////////////////
// CLIENTES
////////////////////////////////////////////////////////////

model Customer {
  id        Int     @id @default(autoincrement())
  uuid      String  @unique @default(uuid())
  name      String
  email     String  @unique
  phone     String  @unique
  password  String
  confirmed Boolean @default(false)
  points    Int     @default(0)

  token          CustomerToken?
  orders         Order[]
  pointMovements PointMovement[]
  couponUsages   CouponUsage[]
}

model CustomerToken {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  token      String
  expiresAt  DateTime
  customerId Int      @unique

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model PointMovement {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  customer Customer @relation(fields: [userId], references: [id], onDelete: Cascade)
}

////////////////////////////////////////////////////////////
// VENTAS Y ENVIOS
////////////////////////////////////////////////////////////

model ShippingDetails {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  recipientName String
  phone         String
  country       String
  department    String
  city          String
  addressLine1  String @db.Text

  // Logística (se llenan después, cuando se hace el envío real)
  trackingNumber  String?
  shippingCompany String?

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  // --- Datos de Facturación SAR ---
  invoiceNumber String? // Ej: "000-001-01-00000027"
  cai           String? // El CAI con el que se generó esta orden
  channel       SaleChannel @default(POS)

  // --- Datos del Cliente y Venta ---
  billingRTN   String @default("S/N")
  customerName String @default("CONSUMIDOR FINAL")
  customerId   Int?

  // -- Datos de Envio --
  deliveryType DeliveryType @default(IN_STORE_PICKUP)
  shippingCost Decimal      @default(0) @db.Decimal(10, 2)

  total          Decimal     @db.Decimal(10, 2)
  status         OrderStatus @default(DELIVERED)
  pointsEarned   Int?        @default(0)
  pointsUsed     Int?        @default(0)
  discountAmount Decimal     @db.Decimal(10, 2)
  userId         Int?
  couponId       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relaciones ---
  customer Customer? @relation(fields: [customerId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  coupon   Coupon?   @relation(fields: [couponId], references: [id])

  orderItems      OrderItem[]
  payment         Payment?
  couponUsage     CouponUsage?
  shippingDetails ShippingDetails?
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  productId Int
  quantity  Int
  discount  Decimal @db.Decimal(10, 2)

  originalCost  Decimal @db.Decimal(10, 2)
  originalPrice Decimal @db.Decimal(10, 2)
  price         Decimal @db.Decimal(10, 2)
  isRedemption  Boolean @default(false)

  orderId Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id            Int           @id @default(autoincrement())
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  transactionId String?       @unique
  orderId       Int           @unique
  createdAt     DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

////////////////////////////////////////////////////////////
// CUPONES
////////////////////////////////////////////////////////////

model Coupon {
  id               Int        @id @default(autoincrement())
  uuid             String     @unique @default(uuid())
  code             String     @unique
  type             CouponType
  value            Decimal    @db.Decimal(10, 2)
  minOrderAmount   Decimal?   @db.Decimal(10, 2)
  maxDiscount      Decimal?   @db.Decimal(10, 2)
  usageLimit       Int?
  usageCount       Int        @default(0)
  perCustomerLimit Int?
  isActive         Boolean    @default(true)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  orders       Order[]
  couponUsages CouponUsage[]
}

model CouponUsage {
  id         Int      @id @default(autoincrement())
  couponId   Int
  customerId Int
  orderId    Int      @unique
  usedAt     DateTime @default(now())

  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, customerId, orderId])
}
